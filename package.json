{
  "name": "lite-dipper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "overrides": {
      "@dicebear/initials@>=9.0.0 <=9.4.0": ">=9.4.1",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:headed": "pnpm build && playwright test --headed",
    "preview": "vite preview",
    "worker:dev": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@cosmjs/crypto": "^0.38.1",
    "@cosmjs/ledger-amino": "^0.38.1",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmjs/stargate": "^0.38.1",
    "@dicebear/collection": "^9.4.0",
    "@dicebear/core": "^9.4.1",
    "@ledgerhq/hw-transport-webhid": "^6.30.7",
    "cosmjs-types": "^0.11.0",
    "long": "^5.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250321.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "wrangler": "^4.7.0"
  }
}
